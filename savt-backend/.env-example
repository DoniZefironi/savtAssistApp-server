# ВАЖНО (прод): пароль БД и JWT-секрет должны быть длинными и случайными.
# Сгенерировать: openssl rand -hex 48
DATABASE_URL=postgresql+asyncpg://postgres:changeme@db:5432/savt
APP_ENV=dev

POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

POSTGRES_DB=savt

# Минимум 64 случайных символа! Сгенерировать: openssl rand -hex 48
JWT_SECRET_KEY=change_me_to_a_long_random_secret
JWT_ACCESS_TOKEN_TTL_MINUTES=30
JWT_REFRESH_TOKEN_TTL_DAYS=60

SMS_CODE_TTL_MINUTES=10
SMS_CODE_MAX_ATTEMPTS=5
SMS_CODE_RESEND_COOLDOWN_SECONDS=60

SMS_PROVIDER=mock
SMSCENTER_LOGIN=your_smscenter_login
SMSCENTER_PASSWORD=your_smscenter_password
SMSCENTER_SENDER=
SMSCENTER_BASE_URL=https://smscentre.by

# CORS: через запятую, например: https://admin.example.com,http://localhost:3000
# Для разработки можно поставить *
CORS_ORIGINS=*

# Firebase (пуш-уведомления)
FIREBASE_CREDENTIALS_PATH=/code/firebase-credentials.json

# Яндекс Cloud (для бота Ася)
YANDEX_FOLDER_ID=your_folder_id
YANDEX_API_KEY=your_api_key
YANDEX_GPT_MODEL=yandexgpt-lite

# Yandex Object Storage — голосовые >1 МБ + офсайт-копии бэкапов БД
YANDEX_STORAGE_BUCKET=
YANDEX_STORAGE_ACCESS_KEY_ID=
YANDEX_STORAGE_SECRET_ACCESS_KEY=
YANDEX_STORAGE_ENDPOINT_URL=https://storage.yandexcloud.net

# Бот
BOT_FOLLOW_UP_MINUTES=60
BOT_MAX_ATTEMPTS=3

# Bitrix24
BITRIX_WEBHOOK_URL=
BITRIX_DEFAULT_RESPONSIBLE_ID=0
BITRIX_DEFAULT_GROUP_ID=0
